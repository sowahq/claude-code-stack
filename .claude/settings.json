{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "language": "french",
  "attribution": { "commit": "", "pr": "" },
  "includeGitInstructions": false,
  "spinnerTipsEnabled": false,
  "autoMemoryEnabled": true,
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/format-check.sh",
            "timeout": 60
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/task-gate.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
